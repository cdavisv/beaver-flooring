{
  "meta": {
    "project": "Beaver Flooring Business Website",
    "version": "1.0.0",
    "themeModes": ["light", "dark"],
    "baseSpacingUnit": 8,
    "notes": [
      "Warm-neutral palette with navy and copper accents.",
      "Semantic tokens should be mapped to implementation variables; components should avoid raw hex usage.",
      "Interactive controls must retain 4.5:1 minimum contrast for text and 3:1 minimum contrast for non-text UI indicators."
    ]
  },
  "color": {
    "primitive": {
      "sand": {
        "0": "#fffaf2",
        "50": "#f7f0e5",
        "100": "#eadfcd",
        "200": "#d7c5aa"
      },
      "stone": {
        "100": "#e7dfd2",
        "200": "#cfc3b3",
        "300": "#a99783",
        "400": "#806f5f"
      },
      "slate": {
        "700": "#445160",
        "800": "#2c3745",
        "900": "#17212b"
      },
      "navy": {
        "700": "#1f3a52",
        "800": "#172c3e",
        "900": "#0f1d29"
      },
      "copper": {
        "400": "#c98d52",
        "500": "#b97738",
        "600": "#995f26",
        "700": "#7a4919"
      },
      "moss": {
        "500": "#55714f",
        "600": "#445c40"
      },
      "amber": {
        "500": "#9b6a14"
      },
      "rust": {
        "500": "#b04b34",
        "600": "#923824"
      }
    },
    "semantic": {
      "light": {
        "bgCanvas": "#fffaf2",
        "bgSurface": "#ffffff",
        "bgMuted": "#f7f0e5",
        "bgAccent": "#1f3a52",
        "fgDefault": "#17212b",
        "fgMuted": "#445160",
        "fgInverse": "#fffaf2",
        "borderSoft": "#e7dfd2",
        "borderStrong": "#a99783",
        "actionPrimary": "#b97738",
        "actionPrimaryHover": "#995f26",
        "actionSecondary": "#1f3a52",
        "actionSecondaryHover": "#172c3e",
        "focusRing": "#995f26",
        "success": "#445c40",
        "warning": "#9b6a14",
        "danger": "#923824"
      },
      "dark": {
        "bgCanvas": "#0f1d29",
        "bgSurface": "#17212b",
        "bgMuted": "#172c3e",
        "bgAccent": "#b97738",
        "fgDefault": "#fffaf2",
        "fgMuted": "#eadfcd",
        "fgInverse": "#17212b",
        "borderSoft": "#445160",
        "borderStrong": "#cfc3b3",
        "actionPrimary": "#c98d52",
        "actionPrimaryHover": "#eadfcd",
        "actionSecondary": "#eadfcd",
        "actionSecondaryHover": "#ffffff",
        "focusRing": "#c98d52",
        "success": "#8eaf88",
        "warning": "#d5a23f",
        "danger": "#d67d68"
      }
    }
  },
  "typography": {
    "fontFamily": {
      "display": "\"Source Serif 4\", Georgia, serif",
      "body": "\"Source Sans 3\", \"Segoe UI\", sans-serif",
      "mono": "\"IBM Plex Mono\", monospace"
    },
    "fontSize": {
      "xs": "12px",
      "sm": "14px",
      "md": "16px",
      "lg": "18px",
      "xl": "22px",
      "2xl": "28px",
      "3xl": "36px",
      "4xl": "48px"
    },
    "lineHeight": {
      "tight": 1.1,
      "snug": 1.25,
      "normal": 1.5,
      "relaxed": 1.7
    },
    "letterSpacing": {
      "tight": "-0.02em",
      "normal": "0",
      "wide": "0.04em"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "spacing": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "24px",
    "6": "32px",
    "7": "48px",
    "8": "64px",
    "9": "96px",
    "10": "128px"
  },
  "radius": {
    "sm": "6px",
    "md": "12px",
    "lg": "20px",
    "pill": "999px"
  },
  "shadow": {
    "soft": "0 8px 24px rgba(23, 33, 43, 0.08)",
    "raised": "0 16px 40px rgba(23, 33, 43, 0.14)"
  },
  "layout": {
    "container": {
      "sm": "640px",
      "md": "1024px",
      "lg": "1280px"
    },
    "breakpoint": {
      "sm": "480px",
      "md": "768px",
      "lg": "1024px",
      "xl": "1280px"
    },
    "touchTargetMin": "44px",
    "sectionPaddingMobile": "48px",
    "sectionPaddingDesktop": "64px"
  },
  "motion": {
    "duration": {
      "fast": "120ms",
      "base": "180ms",
      "slow": "280ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)"
    },
    "notes": [
      "Transitions should be subtle and disabled for users who prefer reduced motion.",
      "Avoid autoplaying carousels or decorative motion that competes with lead-generation actions."
    ]
  },
  "component": {
    "button": {
      "height": {
        "sm": "44px",
        "md": "48px",
        "lg": "56px"
      },
      "paddingInline": {
        "sm": "16px",
        "md": "20px",
        "lg": "24px"
      }
    },
    "input": {
      "height": "48px",
      "minTextareaHeight": "144px"
    },
    "card": {
      "padding": "24px",
      "gap": "16px"
    }
  }
}
